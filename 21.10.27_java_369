import java.io.*;
import java.util.*;
class Main {
	public static void main(String[] args) throws Exception {
		Scanner sc = new Scanner(System.in);
		int in = sc.nextInt();
		int result = 0;
		for(int i = 0; i < in; i++){
			String j = String.valueOf(i);
			for(int k = 0; k < j.length(); k++){
					if(j.charAt(k)=='3'||j.charAt(k)=='6'||j.charAt(k)=='9'){
						result++;
					}
			}
		}
		System.out.print(result);
	}
}
